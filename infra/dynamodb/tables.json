{
  "TableName": "KasiMainTable",
  "BillingMode": "PAY_PER_REQUEST",
  "AttributeDefinitions": [
    { "AttributeName": "PK", "AttributeType": "S" },
    { "AttributeName": "SK", "AttributeType": "S" },
    { "AttributeName": "GSI1PK", "AttributeType": "S" },
    { "AttributeName": "GSI1SK", "AttributeType": "S" },
    { "AttributeName": "GSI2PK", "AttributeType": "S" },
    { "AttributeName": "GSI2SK", "AttributeType": "S" },
    { "AttributeName": "GSI3PK", "AttributeType": "S" }
  ],
  "KeySchema": [
    { "AttributeName": "PK", "KeyType": "HASH" },
    { "AttributeName": "SK", "KeyType": "RANGE" }
  ],
  "GlobalSecondaryIndexes": [
    {
      "IndexName": "GSI1-VendorOrders",
      "KeySchema": [
        { "AttributeName": "GSI1PK", "KeyType": "HASH" },
        { "AttributeName": "GSI1SK", "KeyType": "RANGE" }
      ],
      "Projection": { "ProjectionType": "ALL" }
    },
    {
      "IndexName": "GSI2-CustomerOrders",
      "KeySchema": [
        { "AttributeName": "GSI2PK", "KeyType": "HASH" },
        { "AttributeName": "GSI2SK", "KeyType": "RANGE" }
      ],
      "Projection": { "ProjectionType": "ALL" }
    },
    {
      "IndexName": "GSI3-VendorByWhatsApp",
      "KeySchema": [
        { "AttributeName": "GSI3PK", "KeyType": "HASH" }
      ],
      "Projection": { "ProjectionType": "ALL" }
    }
  ],
  "TimeToLiveSpecification": {
    "AttributeName": "expiresAt",
    "Enabled": true
  },
  "Tags": [
    { "Key": "Project", "Value": "KasiFoodDelivery" },
    { "Key": "Environment", "Value": "production" }
  ],
  "_entityPatterns": {
    "User": {
      "PK": "USER#<userId>",
      "SK": "PROFILE",
      "attributes": ["name", "phone", "email", "role", "isGuest", "createdAt"]
    },
    "Vendor": {
      "PK": "VENDOR#<vendorId>",
      "SK": "PROFILE",
      "GSI3PK": "<whatsappNumber>",
      "attributes": [
        "ownerId", "name", "address", "location", "contactDetails",
        "workingHours", "status", "deliveryType", "deliveryValue",
        "hasBankAccount", "bankDetails", "whatsappNumber",
        "refPrefix",
        "imageUrl", "description", "rating", "totalReviews", "createdAt"
      ],
      "_note": "Set GSI3PK = whatsappNumber when whatsappNumber is present to enable O(1) lookup by WhatsApp number. refPrefix is a 4-char uppercase identifier used to build per-vendor order numbers."
    },
    "VendorPrefixReservation": {
      "PK": "PREFIX#<refPrefix>",
      "SK": "RESERVATION",
      "attributes": [
        "vendorId",
        "createdAt"
      ],
      "_note": "Conditional Put with attribute_not_exists(PK) guarantees globally-unique vendor refPrefixes."
    },
    "OrderCounter": {
      "PK": "VENDOR#<vendorId>",
      "SK": "COUNTER#ORDER#<YYYYMMDD>",
      "attributes": [
        "seq",
        "updatedAt"
      ],
      "_note": "Atomic per-vendor / per-day order sequence. Incremented via UpdateExpression 'ADD seq :one'. Date key uses Africa/Johannesburg timezone so the counter rolls over at local midnight."
    },
    "VendorApplication": {
      "PK": "APPLICATION#<applicationId>",
      "SK": "PROFILE",
      "attributes": [
        "applicantName", "phone", "email", "businessName", "address",
        "description", "hasBankAccount", "whatsappNumber", "status", "createdAt"
      ]
    },
    "MenuItem": {
      "PK": "VENDOR#<vendorId>",
      "SK": "MENU#<menuItemId>",
      "attributes": ["name", "description", "price", "imageUrl", "available", "category", "createdAt"]
    },
    "Order": {
      "PK": "ORDER#<orderId>",
      "SK": "METADATA",
      "GSI1PK": "VENDOR#<vendorId>",
      "GSI1SK": "ORDER#<createdAt>",
      "GSI2PK": "USER#<customerId>",
      "GSI2SK": "ORDER#<createdAt>",
      "attributes": [
        "customerId", "guestDetails", "vendorId", "status",
        "orderNumber",
        "paymentRef",
        "deliveryMethod", "deliveryFee", "subtotal", "totalAmount",
        "paymentMethod", "paymentStatus", "contactPhone",
        "specialInstructions", "source", "createdAt", "updatedAt"
      ],
      "_note": "orderNumber is the human-facing per-vendor identifier (e.g. KOTA-260430-0017); paymentRef is the bank-friendly variant (e.g. KOTA2604300017) used for EFT and PayFast references. Suggested bucket mapping: incoming=PENDING/ACCEPTED, outgoing=PREPARING/READY/OUT_FOR_DELIVERY, completed=COMPLETED (and CANCELLED for exceptions)."
    },
    "OrderItem": {
      "PK": "ORDER#<orderId>",
      "SK": "ITEM#<itemId>",
      "attributes": ["menuItemId", "name", "price", "quantity"]
    },
    "PaymentProof": {
      "PK": "ORDER#<orderId>",
      "SK": "POP#<paymentProofId>",
      "attributes": [
        "vendorId",
        "senderPhone",
        "senderName",
        "amount",
        "reference",
        "note",
        "attachmentName",
        "channel",
        "status",
        "receivedAt",
        "createdAt",
        "updatedAt"
      ],
      "_note": "Stores WhatsApp proof-of-payment (PoP) metadata. Media file URLs/keys can be attached in note or added as a future s3Key attribute."
    },
    "RevenueEntry": {
      "PK": "VENDOR#<vendorId>",
      "SK": "REV#<saleDate>#<entryId>",
      "attributes": [
        "orderId",
        "source",
        "grossAmount",
        "netAmount",
        "paymentMethod",
        "note",
        "saleDate",
        "createdBy",
        "createdAt"
      ],
      "_note": "Supports manual sales capture and ERP-style financial tracking per vendor."
    },
    "InventoryItem": {
      "PK": "VENDOR#<vendorId>",
      "SK": "INV#<inventoryItemId>",
      "attributes": [
        "name",
        "sku",
        "unit",
        "quantityOnHand",
        "reorderLevel",
        "unitCost",
        "status",
        "createdAt",
        "updatedAt"
      ],
      "_note": "Inventory baseline for future ERP integrations, stock alerts, and procurement workflows."
    },
    "Session": {
      "PK": "SESSION#<customerPhone>",
      "SK": "VENDOR#<vendorId>",
      "TTL": "expiresAt",
      "attributes": [
        "currentStep", "cart", "menuContext", "customerName",
        "expiresAt", "updatedAt"
      ],
      "_steps": ["START", "SELECTING_ITEMS", "CONFIRM_ORDER", "PAYMENT", "DONE"],
      "_note": "expiresAt is a Unix timestamp (seconds). Sessions expire 30 minutes after last activity via DynamoDB TTL."
    },
    "Review": {
      "PK": "VENDOR#<vendorId>",
      "SK": "REVIEW#<reviewId>",
      "attributes": ["userId", "guestName", "rating", "comment", "createdAt"]
    }
  }
}
